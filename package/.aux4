            "variables": [
              {
                "name": "startDate",
                "text": "Start date (YYYY-MM-DD)"
              },
              {
                "name": "endDate",
                "text": "End date (YYYY-MM-DD)"
              },
              {
                "name": "metricTypes",
                "text": "Comma-separated metric types",
                "default": "IMPRESSION,PIN_CLICK,SAVE"
              },
              {
                "name": "tokenFile",
                "text": "Custom token file path",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "followers",
          "execute": [
            "aux4 curl auth-request --provider pinterest --tokenFile ${tokenFile} \"https://api.pinterest.com/v5/user_account/followers?page_size=${pageSize}&bookmark=${bookmark}\""
          ],
          "help": {
            "text": "List followers",
            "variables": [
              {
                "name": "pageSize",
                "text": "Number of followers to return",
                "default": "25"
              },
              {
                "name": "bookmark",
                "text": "Pagination bookmark from previous response",
                "default": ""
              },
              {
                "name": "tokenFile",
                "text": "Custom token file path",
                "default": ""
              }
            ]
          }
        }
      ]
    },
    {
      "name": "pinterest:media",
      "commands": [
        {
          "name": "upload",
          "execute": [
            "aux4 curl auth-request --provider pinterest --tokenFile ${tokenFile} --method POST --header \"Content-Type: application/json\" --body ${body} https://api.pinterest.com/v5/media"
          ],
          "help": {
            "text": "Register a media upload",
            "variables": [
              {
                "name": "body",
                "text": "Media upload data as JSON (media_type)"
              },
              {
                "name": "tokenFile",
                "text": "Custom token file path",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "list",
          "execute": [
            "aux4 curl auth-request --provider pinterest --tokenFile ${tokenFile} \"https://api.pinterest.com/v5/media?page_size=${pageSize}&bookmark=${bookmark}\""
          ],
          "help": {
            "text": "List media uploads",
            "variables": [
              {
                "name": "pageSize",
                "text": "Number of uploads to return",
                "default": "25"
              },
              {
                "name": "bookmark",
                "text": "Pagination bookmark from previous response",
                "default": ""
              },
              {
                "name": "tokenFile",
                "text": "Custom token file path",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "get",
          "execute": [
            "aux4 curl auth-request --provider pinterest --tokenFile ${tokenFile} https://api.pinterest.com/v5/media/${mediaId}"
          ],
          "help": {
            "text": "Get media upload status",
            "variables": [
              {
                "name": "mediaId",
                "text": "Media upload ID",
                "arg": true
              },
              {
                "name": "tokenFile",
                "text": "Custom token file path",
                "default": ""
              }
            ]
          }
        }
      ]
    }
  ]
}
